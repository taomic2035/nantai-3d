# 无限村庄世界生成系统 - 环境变量模板
# 复制为 .env 并填入实际值

# GLM API (布局生成 L2)
# 注册: https://bigmodel.cn  注册送1亿免费token
ZHIPU_API_KEY=

# AutoDL 云端 GPU (L1/L0 GPU任务)
# 可选, 仅在需要本地触发云端任务时使用
AUTODL_TOKEN=

# 腾讯混元3D (在线API, 备选)
# https://3d.hunyuan.tencent.com
HUNYUAN_TOKEN=

# 项目根目录 (可选, 默认自动检测)
# PROJECT_ROOT=/path/to/nantai-3d
